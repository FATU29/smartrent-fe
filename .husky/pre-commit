#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Load nvm so hooks run with the project's Node version instead of the system default
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh" --no-use 2>/dev/null
nvm use --silent 2>/dev/null || true

echo "🔍 Running pre-commit checks..."

# Type checking
echo "\n📝 Type checking..."
npm run typecheck || exit 1

# i18n validation
echo "\n🌍 Validating translations..."
npm run i18n:check || exit 1

# Lint and format staged files
echo "\n✨ Linting and formatting staged files..."
npx lint-staged || exit 1

echo "\n✅ All pre-commit checks passed!"
